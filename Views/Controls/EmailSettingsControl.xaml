<UserControl x:Class="cpu_net.Views.Controls.EmailSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="580" d:DesignWidth="500">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <CheckBox x:Name="EnabledCheckBox" Content="启用邮件提醒" Margin="0,5" FontSize="14"/>
        
        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <TextBlock Grid.Row="0" Grid.Column="0" Text="SMTP服务器:" VerticalAlignment="Center" FontSize="14"/>
            <TextBox x:Name="SmtpServerTextBox" Grid.Row="0" Grid.Column="1" FontSize="14" Padding="5,2" Margin="5,5" Text="smtp.qq.com"/>
            
            <TextBlock Grid.Row="1" Grid.Column="0" Text="SMTP端口:" VerticalAlignment="Center" FontSize="14"/>
            <TextBox x:Name="SmtpPortTextBox" Grid.Row="1" Grid.Column="1" Width="100" HorizontalAlignment="Left" FontSize="14" Padding="5,2" Margin="5,5" Text="587"/>
            
            <TextBlock Grid.Row="2" Grid.Column="0" Text="邮箱账号:" VerticalAlignment="Center" FontSize="14"/>
            <TextBox x:Name="UsernameTextBox" Grid.Row="2" Grid.Column="1" FontSize="14" Padding="5,2" Margin="5,5"/>
            
            <TextBlock Grid.Row="3" Grid.Column="0" Text="授权码/密码:" VerticalAlignment="Center" FontSize="14"/>
            <PasswordBox x:Name="PasswordBox" Grid.Row="3" Grid.Column="1" FontSize="14" Padding="5,2" Margin="5,5"/>
            
            <TextBlock Grid.Row="4" Grid.Column="0" Text="收件人:" VerticalAlignment="Center" FontSize="14"/>
            <TextBox x:Name="ToTextBox" Grid.Row="4" Grid.Column="1" FontSize="14" Padding="5,2" Margin="5,5"/>
            
            <!-- 电费提醒模板 -->
            <TextBlock Grid.Row="5" Grid.Column="0" Text="提醒主题:" VerticalAlignment="Center" FontSize="14"/>
            <TextBox x:Name="AlertSubjectTextBox" Grid.Row="5" Grid.Column="1" FontSize="14" Padding="5,2" Margin="5,5"/>
            
            <TextBlock Grid.Row="6" Grid.Column="0" Text="提醒正文:" VerticalAlignment="Top" FontSize="14" Margin="0,5,0,0"/>
            <TextBox x:Name="AlertBodyTextBox" Grid.Row="6" Grid.Column="1" FontSize="12" Padding="5,2" Margin="5,5" 
                     AcceptsReturn="True" TextWrapping="Wrap" Height="70" VerticalScrollBarVisibility="Auto"/>
            
            <!-- 未绑定房间模板 -->
            <TextBlock Grid.Row="7" Grid.Column="0" Text="异常主题:" VerticalAlignment="Center" FontSize="14"/>
            <TextBox x:Name="NotBoundSubjectTextBox" Grid.Row="7" Grid.Column="1" FontSize="14" Padding="5,2" Margin="5,5"/>
            
            <TextBlock Grid.Row="8" Grid.Column="0" Text="异常正文:" VerticalAlignment="Top" FontSize="14" Margin="0,5,0,0"/>
            <TextBox x:Name="NotBoundBodyTextBox" Grid.Row="8" Grid.Column="1" FontSize="12" Padding="5,2" Margin="5,5" 
                     AcceptsReturn="True" TextWrapping="Wrap" Height="70" VerticalScrollBarVisibility="Auto"/>
            
            <Button x:Name="TestButton" Grid.Row="9" Grid.Column="1" Content="发送测试邮件" Width="120" Height="30" Margin="5,10,0,0" HorizontalAlignment="Left" Click="TestButton_Click"/>
            
            <TextBlock Grid.Row="10" Grid.Column="1" TextWrapping="Wrap" FontSize="11" Foreground="#888" Margin="5,8,0,0">
                可用占位符：{balance} 余额、{threshold} 阈值、{roomInfo} 房间、{studentNo} 学号、{time} 时间
            </TextBlock>
        </Grid>
        
        <TextBlock Grid.Row="3" TextWrapping="Wrap" FontSize="12" Foreground="#666" Margin="0,10,0,0" VerticalAlignment="Bottom">
            提示：QQ邮箱请使用授权码而非登录密码。其他邮箱请确认SMTP服务器地址和端口是否正确。
        </TextBlock>
    </Grid>
</UserControl>
