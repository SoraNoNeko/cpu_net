<Page x:Class="cpu_net.Views.Pages.ConfigurationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:cpu_net.Views.Pages"
      xmlns:controls="clr-namespace:cpu_net.Views.Controls"
      xmlns:vm="clr-namespace:cpu_net.ViewModel"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ConfigurationPage">
    <Page.Resources>
        <vm:CarrierViewModel x:Key="carrierVM"/>
        <vm:UserViewModel x:Key="userVM"/>
    </Page.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- 左侧菜单 -->
        <Border Grid.Column="0" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0" Background="#F5F5F5">
            <ListBox x:Name="MenuListBox" BorderThickness="0" Background="Transparent">
                <ListBoxItem Content="网络设置" Tag="network" IsSelected="True" Padding="15,10" FontSize="14"/>
                <ListBoxItem Content="电费设置" Tag="electricity" Padding="15,10" FontSize="14"/>
                <ListBoxItem Content="邮件设置" Tag="email" Padding="15,10" FontSize="14"/>
                <ListBoxItem Content="背景与图标" Tag="background" Padding="15,10" FontSize="14"/>
                <ListBoxItem Content="关于" Tag="about" Padding="15,10" FontSize="14"/>
            </ListBox>
        </Border>
        
        <!-- 右侧内容区 -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" x:Name="ContentScrollViewer">
                <StackPanel Margin="20">
                    
                    <!-- 网络设置面板 -->
                    <Grid x:Name="NetworkPanel">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Text="网络设置" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>
                        
                        <CheckBox Grid.Row="1" Name="NetworkEnabledCheckBox" Content="启用网络登录" FontSize="14" Margin="0,0,0,15"
                                  IsChecked="{Binding Path=NetworkLoginEnabled,Source={StaticResource userVM}}"/>
                        
                        <!-- 账户信息 -->
                        <Border Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,15"
                                Background="White">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="账户信息" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="250"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="32"/>
                                        <RowDefinition Height="32"/>
                                        <RowDefinition Height="32"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="学  号:" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" Name="code" FontSize="14" Padding="3" 
                                             PreviewTextInput="Code_PreviewTextInput" InputMethod.IsInputMethodEnabled="False" 
                                             Text="{Binding Path=Code, Source={StaticResource userVM}}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="密  码:" FontSize="14" VerticalAlignment="Center"/>
                                    <PasswordBox Grid.Row="1" Grid.Column="1" Name="secret" FontSize="14" Padding="3" 
                                                 InputMethod.IsInputMethodEnabled="False" 
                                                 vm:LoginPasswordBoxHelper.IsPasswordBindingEnable="True"
                                                 vm:LoginPasswordBoxHelper.Password="{Binding Path=Password, Source={StaticResource userVM}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="运营商:" FontSize="14" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="2" Grid.Column="1" Name="carrier" FontSize="14" Padding="3"
                                              ItemsSource="{Binding Path=ComboxList,Mode=TwoWay,Source={StaticResource carrierVM}}" 
                                              SelectedItem="{Binding Path=ComboxItem,Mode=TwoWay,Source={StaticResource carrierVM}}" 
                                              DisplayMemberPath="Text" SelectedValuePath="Key"/>
                                </Grid>
                            </Grid>
                        </Border>
                        
                        <!-- 登录模式与选项 -->
                        <Grid Grid.Row="3">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="启动选项" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <StackPanel>
                                        <CheckBox Name="AutoRun" Margin="0,3" IsChecked="{Binding Path=IsAutoRun,Source={StaticResource userVM}}">开机启动</CheckBox>
                                        <CheckBox Name="AutoLogin" Margin="0,3" IsChecked="{Binding Path=IsAutoLogin,Source={StaticResource userVM}}">自动登录</CheckBox>
                                        <CheckBox Name="AutoMin" Margin="0,3" IsChecked="{Binding Path=IsAutoMin,Source={StaticResource userVM}}">自动最小化</CheckBox>
                                        <CheckBox Name="SetLogin" Margin="0,3" IsChecked="{Binding Path=IsSetLogin,Source={StaticResource userVM}}">定时检测</CheckBox>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="登录模式" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <StackPanel>
                                        <RadioButton Name="ppp" GroupName="Mode" Margin="0,3" Command="{Binding Path=PppButton_Click,Source={StaticResource userVM}}">宽带</RadioButton>
                                        <RadioButton Name="cpu" GroupName="Mode" Margin="0,3" Command="{Binding Path=CpuButton_Click,Source={StaticResource userVM}}">CPU</RadioButton>
                                        <RadioButton Name="auto" GroupName="Mode" Margin="0,3" Command="{Binding Path=AutoButton_Click,Source={StaticResource userVM}}">自动</RadioButton>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                            
                            <Grid Grid.Row="1" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="定时时长:" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" Name="loginTime" FontSize="14" Padding="3" 
                                         PreviewTextInput="Code_PreviewTextInput" InputMethod.IsInputMethodEnabled="False" 
                                         Text="{Binding Path=LoginTime, Source={StaticResource userVM}}"/>
                                <TextBlock Grid.Column="2" Text="秒" FontSize="14" VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </Grid>
                            
                            <TextBlock Grid.Row="2" TextWrapping="Wrap" FontSize="12" Foreground="#666" Margin="0,0,0,15">
                                在宿舍登录模式请选择宽带，在宿舍外请选择CPU。连接出现问题可尝试自动模式。
                            </TextBlock>
                        </Grid>
                    </Grid>
                    
                    <!-- 电费设置面板 -->
                    <controls:ElectricitySettingsControl x:Name="ElectricitySettings" Margin="0,40,0,0"/>
                    
                    <!-- 邮件设置面板 -->
                    <controls:EmailSettingsControl x:Name="EmailSettings" Margin="0,40,0,0"/>
                    
                    <!-- 背景设置面板 -->
                    <controls:BackgroundSettingsControl x:Name="BackgroundSettings" Margin="0,40,0,0"/>
                    
                    <!-- 关于面板 -->
                    <Grid x:Name="AboutPanel" Margin="0,40,0,0">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,40">
                            <TextBlock Text="CPU_NET" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="校园网自动登录工具" FontSize="14" Foreground="Gray" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                            <TextBlock Text="Developed BY 二阶堂真红" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock HorizontalAlignment="Center">
                                <Hyperlink Click="Hyperlink_Click" FontSize="14">代码发布页</Hyperlink>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
            
            <!-- 底部固定按钮 -->
            <Border Grid.Row="1" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Background="#FAFAFA" Padding="0,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="保存" Name="SaveButton" Width="100" Height="36" FontSize="14" Click="SaveButton_Click" Margin="0,0,15,0"/>
                    <Button Content="取消" Name="CancelButton" Width="100" Height="36" FontSize="14" Click="CancelButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
