<Window x:Class="cpu_net.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:cpu_net"
        xmlns:pages="clr-namespace:cpu_net.Views.Pages"
        xmlns:vm="clr-namespace:cpu_net.ViewModel"
        Icon="shinnku.ico"
        mc:Ignorable="d"
        Closing="Window_Closing"
        StateChanged="Window_StateChanged"
        Title="CPU网络连接" Height="500" Width="800" TextBlock.TextAlignment="Center"
        MinHeight="500" MinWidth="800">
    <Grid x:Name="MainGrid">
        <Grid.Background>
            <SolidColorBrush Color="White"/>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="35"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- 顶部导航栏 -->
        <Grid Grid.Row="0" Background="White">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" x:Name="Home_Button" Content="主    页" HorizontalAlignment="Center" VerticalAlignment="Center" 
                    BorderBrush="White" FontSize="15" Foreground="Black" BorderThickness="0,0,0,2" Padding="20,5" 
                    Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Click="Home_Button_Click"/>
            <Button Grid.Column="1" x:Name="Elec_Button" Content="电费查询" HorizontalAlignment="Center" VerticalAlignment="Center" 
                    BorderBrush="White" FontSize="15" Foreground="Black" BorderThickness="0,0,0,2" Padding="20,5" 
                    Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Click="Elec_Button_Click"/>
            <Button Grid.Column="2" x:Name="Conf_Button" Content="设    置" HorizontalAlignment="Center" VerticalAlignment="Center" 
                    BorderBrush="White" FontSize="15" Foreground="Black" BorderThickness="0,0,0,2" Padding="20,5" 
                    Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Click="Conf_Button_Click"/>
        </Grid>
        <!-- 内容区 -->
        <Frame x:Name="PageFrame" Grid.Row="1" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>
